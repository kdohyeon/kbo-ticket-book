# Firebase (Firebase Console > 프로젝트 설정 > 앱)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google 로그인
# 발급처: https://console.cloud.google.com > API 및 서비스 > 사용자 인증 정보
# Firebase Console > Authentication > Sign-in method > Google 활성화 후 확인 가능
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Kakao 로그인
# 발급처: https://developers.kakao.com > 애플리케이션 > 앱 키
EXPO_PUBLIC_KAKAO_REST_API_KEY=
# Kakao 백엔드 커스텀 토큰 발급 엔드포인트 (Firebase Cloud Function URL)
EXPO_PUBLIC_KAKAO_CUSTOM_TOKEN_ENDPOINT=

# Apple 로그인 (iOS 전용 - 코드 설정 불필요, app.json 플러그인으로 처리)
# Apple Developer > Certificates, Identifiers & Profiles > Identifiers > Sign In with Apple 활성화 필요
